# ── Supabase (proyecto) ──────────────────────────────────────────────────────
# Obtén estos valores en supabase.com → Project Settings → API

VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
VITE_SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui

SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui

# ⚠ SECRETO — nunca expongas esta clave en el cliente (sin prefijo VITE_)
# Requerida para operaciones admin (crear usuarios, etc.)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── Mailjet (envío de correos) ────────────────────────────────────────────────
# Obtén estos valores en app.mailjet.com → Account Settings → REST API → API Key Management
# ⚠ SECRETO — nunca expongas MAILJET_SECRET_KEY en el cliente ni la subas a git
MAILJET_API_KEY=tu_mailjet_api_key_aqui
MAILJET_SECRET_KEY=tu_mailjet_secret_key_aqui

# Remitente verificado en Mailjet (Account Settings → Sender addresses & domains)
MAILJET_FROM_EMAIL=notificaciones@tu-dominio.com
MAILJET_FROM_NAME="Plataforma de Solicitudes — UdeCataluña"

# Correo interno de Financiera al que se copian las notificaciones de aprobación
FINANCIERA_NOTIFY_EMAIL=nicolas.alarcon@ucatalunya.edu.co

# ── URL del sitio ────────────────────────────────────────────────────────────
# URL base usada en los links de los correos enviados
SITE_URL=https://tu-dominio.com
